{
  "name": "synclair",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "license": "GPL-3.0-or-later",
  "homepage": "https://synclair.dev",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "check:registry": "node scripts/check-registry.mjs",
    "check:previews": "node scripts/check-previews.mjs",
    "check:host": "node scripts/check-host-drift.mjs",
    "check:coverage": "node scripts/check-host-coverage.mjs",
    "scan:hygiene": "node scripts/scan-host-hygiene.mjs",
    "check:ux-docs": "node scripts/check-ux-docs.mjs",
    "check:pages": "node scripts/check-pages.mjs",
    "resolve:pages": "node scripts/resolve-page-items.mjs",
    "host:status": "node scripts/host-servers.mjs status",
    "host:up": "node scripts/host-servers.mjs up",
    "call-home": "node scripts/call-home.mjs",
    "verify-ui": "npm run typecheck && npm run lint && npm run check:registry && npm run check:previews && npm run check:ux-docs && npm run check:pages",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.23.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
